APP_NAME=Talashow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Production recommandé : APP_ENV=production, APP_DEBUG=false, LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=database
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Sécurité HTTP (CSP) : off | enforce | report
SECURITY_CSP_MODE=enforce
SECURITY_HSTS_MAX_AGE=31536000

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# Lecture vidéo : Bunny Stream
VIDEO_PROVIDER=bunny
# Optionnel (réservé) : VIDEO_FALLBACK_PROVIDER=
# hls (Video.js + m3u8) | bunny_embed (iframe Bunny — URL /play/ par défaut)
VIDEO_PLAYBACK_DRIVER=bunny_embed
# play = player.mediadelivery.net/play/... | embed = iframe.mediadelivery.net/embed/...
BUNNY_STREAM_IFRAME_URL_STYLE=play
# Dossier contenant {clé}.mp4 pour php artisan video:migrate-cloudflare-to-bunny (clé = UID 32 car. ou nom fichier)
VIDEO_MIGRATION_LOCAL_BASE=

# Bunny Stream (https://video.bunnycdn.com)
BUNNY_STREAM_LIBRARY_ID=
BUNNY_STREAM_API_KEY=
BUNNY_STREAM_CDN_HOSTNAME=
BUNNY_STREAM_PULL_ZONE=
BUNNY_STREAM_API_BASE=https://video.bunnycdn.com
BUNNY_STREAM_EMBED_BASE=https://iframe.mediadelivery.net/embed
BUNNY_STREAM_PLAYER_BASE=https://player.mediadelivery.net/play
BUNNY_STREAM_SIGNED_URLS=false
BUNNY_STREAM_TOKEN_KEY=
BUNNY_STREAM_TOKEN_SECURITY_KEY=
BUNNY_STREAM_TOKEN_AUTH_ENABLED=false
BUNNY_STREAM_URL_EXPIRATION=3600
BUNNY_STREAM_WEBHOOK_SECRET=
BUNNY_STREAM_UPLOAD_TIMEOUT=3600
BUNNY_STREAM_TIMEOUT=120
BUNNY_STREAM_COLLECTIONS_ENABLED=true
BUNNY_VERIFY_SSL=true

# Gate lecture + TTL Bunny (config/video_security.php)
VIDEO_SECURITY_PLAYBACK_GATE=false
VIDEO_SECURITY_SIGNED_ENABLED=true
VIDEO_SECURITY_HARDEN_BUNNY_TTL=true
VIDEO_SECURITY_TOKEN_TTL=120
VIDEO_SECURITY_SESSION_TTL=360
VIDEO_SECURITY_MAX_CONCURRENT=2
VIDEO_SECURITY_MAX_DEVICES=5
VIDEO_SECURITY_ALLOWED_REFERRERS=
VIDEO_SECURITY_GEO_BLOCK=false
VIDEO_SECURITY_AUDIT=true
VIDEO_SECURITY_REQUIRE_LOGIN=false
VIDEO_SECURITY_MAX_IPS_DAY=12
VIDEO_SECURITY_SHADOW_THRESHOLD=80

# Bunny Storage — images (posters, covers, miniatures, logo) via pull zone
BUNNY_STORAGE_ZONE_NAME=
BUNNY_STORAGE_REGION=de
BUNNY_STORAGE_API_KEY=
BUNNY_STORAGE_CDN_URL=
# Windows / PHP sans bundle CA : erreur cURL 60 → mettre false (ou désactiver SSL dans Paramètres admin)
BUNNY_STORAGE_VERIFY_SSL=false

# Stripe (paiement / webhooks)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# OAuth (Socialite) — URLs de callback basées sur APP_URL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Tawk.to (optionnel)
TAWK_TO_ENABLED=true
TAWK_TO_EMBED_URL=
